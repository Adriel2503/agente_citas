# =============================================================================
# Agent Citas — MaravIA
# Copiar como .env y reemplazar los valores marcados con <REEMPLAZAR>
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=<REEMPLAZAR>
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.5
OPENAI_TIMEOUT=60
MAX_TOKENS=2048

# --- Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8002
CHAT_TIMEOUT=120

# --- Logging ---
# Niveles: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_FILE=

# --- HTTP y reintentos ---
API_TIMEOUT=10
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_WAIT_MIN=1
HTTP_RETRY_WAIT_MAX=4

# --- Circuit breaker (threshold fallos → abierto; reset tras TTL segundos) ---
CB_THRESHOLD=3
CB_RESET_TTL=300
CB_MAX_KEYS=500

# --- HTTP connection pool ---
HTTP_MAX_CONNECTIONS=50
HTTP_MAX_KEEPALIVE=20

# --- Concurrencia del agente (backpressure) ---
MAX_CONCURRENT_AGENT=50

# --- Caché (minutos / maxsize) ---
AGENT_CACHE_TTL_MINUTES=60
AGENT_CACHE_MAXSIZE=500
SEARCH_CACHE_TTL_MINUTES=15
SEARCH_CACHE_MAXSIZE=2000
MAX_MESSAGES_HISTORY=20

# --- Base de datos y Redis ---
# DATABASE_URL=postgresql://user:password@host:5432/citas
REDIS_URL=
REDIS_CHECKPOINT_TTL_HOURS=24  # 0 = sin TTL (no expiran), default 24h

# --- Zona horaria ---
TIMEZONE=America/Lima

# --- APIs MaravIA ---
API_CALENDAR_URL=https://api.maravia.pe/servicio/ws_calendario.php
API_AGENDAR_REUNION_URL=https://api.maravia.pe/servicio/ws_agendar_reunion.php
API_INFORMACION_URL=https://api.maravia.pe/servicio/ws_informacion_ia.php
API_PREGUNTAS_FRECUENTES_URL=https://api.maravia.pe/servicio/n8n/ws_preguntas_frecuentes.php

# --- LangSmith tracing (opcional) ---
# LangChain/LangGraph las lee automáticamente del ambiente.
# Desactivado por defecto. Activar para observabilidad de traces, tools y LLM calls.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=<tu_langsmith_api_key>
# LANGSMITH_PROJECT="Agente_Citas"
